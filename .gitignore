# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Bytecode in src/ layout
src/**/__pycache__/
src/**/*.py[cod]

# Virtual environment directories
venv/
.env/
.envrc
.venv/

# Editor backup and swap files
*~
*.swp
*.swo
*.bak

# Emacs temporary and backup files
.#*
*~

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/

# PyInstaller files
*.manifest
*.spec

# Test result and coverage reports
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Test output and caches
.tox/
.nox/
htmlcov/
.coverage*
.cache

# Documentation output
docs/_build/

# Package manager lock files
pdm.lock
poetry.lock
pixi.lock
.pdm*

# PEP 582 local package folders
__pypackages__/

# Cython debug directory
cython_debug/

# Debian build artifacts (avoid committing .deb package files, metadata, or temporary Debian files)
*.deb
*.dsc
*.changes
*.buildinfo
debian/*.debhelper
debian/*.substvars
debian/*.log
debian/*-stamp
debian/files
debian/tmp

# Log files
*.log

# System files
.DS_Store
Thumbs.db

# Compiled C extensions and shared libs
*.so
*.dll
*.dylib

# Local environment or IDE settings
.envrc
.idea/
.vscode/

# No playground
notebook_playground/
